{
    "database": {
        "path": "data/events.db",
        "wal_mode": true
    },
    "writer": {
        "batch_size": 100,
        "flush_interval_ms": 200
    },
    "syslog": {
        "enabled": true,
        "host": "0.0.0.0",
        "port": 514
    },
    "snmptrap": {
        "enabled": true,
        "host": "0.0.0.0",
        "port": 162,
        "community": "simplenms",
        "mib_dirs": ["/opt/simple-nms/data/mibs", "/usr/share/snmp/mibs"]
    },
    "webhook": {
        "enabled": true,
        "host": "0.0.0.0",
        "port": 80
    }
}
