{
    "database": {
        "path": "data/events.db",
        "wal_mode": true
    },
    "writer": {
        "batch_size": 100,
        "flush_interval_ms": 200
    },
    "syslog": {
        "enabled": true,
        "host": "0.0.0.0",
        "port": 514
    },
    "snmptrap": {
        "enabled": true,
        "host": "0.0.0.0",
        "port": 162,
        "community": "simplenms",
        "mib_dirs": ["/usr/share/snmp/mibs", "/home/genie/mibs"],
        "mib_modules": [
        "SNMPv2-MIB", "SNMPv2-SMI", "SNMPv2-TC", "SNMPv2-TM", "SNMPv2-CONF",
        "IF-MIB", "IF-INVERTED-STACK-MIB",
        "IP-MIB", "IP-FORWARD-MIB",
        "TCP-MIB", "UDP-MIB",
        "HOST-RESOURCES-MIB", "HOST-RESOURCES-TYPES",
        "RFC1155-SMI", "RFC1213-MIB",
        "SNMP-FRAMEWORK-MIB", "SNMP-MPD-MIB",
        "SNMP-TARGET-MIB", "SNMP-NOTIFICATION-MIB",
        "SNMP-COMMUNITY-MIB", "SNMP-PROXY-MIB",
        "SNMP-USER-BASED-SM-MIB", "SNMP-USM-AES-MIB", "SNMP-USM-DH-OBJECTS-MIB",
        "SNMP-VIEW-BASED-ACM-MIB",
        "INET-ADDRESS-MIB", "TRANSPORT-ADDRESS-MIB",
        "IANA-ADDRESS-FAMILY-NUMBERS-MIB", "IANAifType-MIB", "IANA-LANGUAGE-MIB", "IANA-RTPROTO-MIB",
        "HCNUM-TC", "IPV6-TC",
        "IPV6-MIB", "IPV6-ICMP-MIB", "IPV6-TCP-MIB", "IPV6-UDP-MIB", "IPV6-FLOW-LABEL-MIB",
        "EtherLike-MIB", "TUNNEL-MIB", "RMON-MIB",
        "NOTIFICATION-LOG-MIB", "AGENTX-MIB", "SMUX-MIB",
        "NETWORK-SERVICES-MIB", "MTA-MIB",
        "DISMAN-EVENT-MIB", "DISMAN-EXPRESSION-MIB", "DISMAN-SCHEDULE-MIB",
        "DISMAN-SCRIPT-MIB", "DISMAN-NSLOOKUP-MIB", "DISMAN-PING-MIB", "DISMAN-TRACEROUTE-MIB",
        "NET-SNMP-MIB", "NET-SNMP-TC", "NET-SNMP-AGENT-MIB", "NET-SNMP-EXTEND-MIB",
        "NET-SNMP-EXAMPLES-MIB", "NET-SNMP-MONITOR-MIB", "NET-SNMP-SYSTEM-MIB",
        "NET-SNMP-VACM-MIB", "NET-SNMP-PASS-MIB",
        "UCD-SNMP-MIB", "UCD-SNMP-MIB-OLD", "UCD-DEMO-MIB",
        "UCD-DISKIO-MIB", "UCD-DLMOD-MIB", "UCD-IPFILTER-MIB", "UCD-IPFWACC-MIB",
        "LM-SENSORS-MIB", "RFC-1215"
    ]
    },
    "webhook": {
        "enabled": true,
        "host": "0.0.0.0",
        "port": 80
    }
}
