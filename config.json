{
    "database": {
        "path": "data/events.db",
        "wal_mode": true
    },
    "writer": {
        "batch_size": 100,
        "flush_interval_ms": 200
    },
    "syslog": {
        "enabled": true,
        "host": "0.0.0.0",
        "port": 514
    },
    "syslog_tls": {
        "enabled": false,
        "host": "0.0.0.0",
        "port": 6514,
        "certfile": "data/tls/server.crt",
        "keyfile": "data/tls/server.key",
        "require_client_cert": false
    },
    "snmptrap": {
        "enabled": true,
        "host": "0.0.0.0",
        "port": 162,
        "community": "simplenms",
        "mib_dirs": ["/opt/simple-nms/data/mibs", "/usr/share/snmp/mibs"]
    },
    "webhook": {
        "enabled": true,
        "host": "0.0.0.0",
        "port": 80
    }
}
